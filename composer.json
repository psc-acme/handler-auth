{
    "name": "psc-acme/handler-auth",
    "description": "Package handler-auth for psc-acme organization",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\HandlerAuth\\": "src/"
        }
    },
    "require": {
        "php": ">=8.3",
        "league/commonmark": "^2.0",
        "symfony/cache": "^7.0",
        "spatie/laravel-permission": "^6.0"
    },
    "require-dev": {
        "vimeo/psalm": "^5.0",
        "webforge/object-asserter": "^2.0.0",
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "minimum-stability": "dev",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}